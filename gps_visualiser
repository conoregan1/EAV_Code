import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.colors as mcolors
from matplotlib.ticker import FuncFormatter
from datetime import datetime
import os
import contextily as cx
from text_to_excel import process_data_file


def plot_gps_data(csv_file_path):
    try:
        df = pd.read_csv(csv_file_path)

        # --- Data Validation ---
        required_columns = ['Lat', 'Long', 'Time']
        if not all(col in df.columns for col in required_columns):
            print(f"Error: CSV file must contain the columns: {required_columns}")
            return

        # --- Data Processing ---
        df.dropna(subset=['Lat', 'Long'], inplace=True)
        if df.empty:
            print("No valid GPS coordinates to plot.")
            return

        df['time_dt'] = pd.to_datetime(df['Time'], format='%H:%M:%S')
        df.sort_values('time_dt', inplace=True)
        time_numeric = (df['time_dt'] - df['time_dt'].min()).dt.total_seconds()

        # --- Plotting ---
        fig, ax = plt.subplots(figsize=(12, 12))

        cmap_rgb = mcolors.LinearSegmentedColormap.from_list(
            "RedGreenBlue", ["red", "green", "blue"]
        )

        # Plot directly in latitude/longitude
        scatter = ax.scatter(
            df['Long'],
            df['Lat'],
            c=time_numeric,
            cmap=cmap_rgb,
            s=25,
            alpha=0.8,
            zorder=2
        )

        # --- Add OSM Map Overlay ---
        # Tell contextily that the axes are in lat/long (EPSG:4326)
        try:
            cx.add_basemap(
                ax,
                source=cx.providers.OpenStreetMap.Mapnik,
                crs="EPSG:4326",
                zoom='auto'
            )
        except Exception as e:
            print(f"Warning: Could not load map tiles: {e}")

        # --- Formatting and Labels ---
        cbar = fig.colorbar(scatter, ax=ax, fraction=0.046, pad=0.04)
        cbar.set_label('Time Progression (from start)', rotation=270, labelpad=20)

        min_time = df['time_dt'].min()
        formatter = FuncFormatter(
            lambda s, x: (min_time + pd.to_timedelta(s, unit='s')).strftime('%H:%M:%S')
        )
        cbar.ax.yaxis.set_major_formatter(formatter)

        ax.set_title(
            f'GPS Path - {datetime.now().strftime("%Y-%m-%d")}',
            fontsize=16
        )

        # Make map look square
        ax.set_aspect('equal')

        plt.tight_layout()
        plt.show()

    except FileNotFoundError:
        print(f"Error: The file '{csv_file_path}' was not found.")
    except Exception as e:
        print(f"An unexpected error occurred: {e}")


def main():
    data_file_path = 'D:/data.txt'
    output_directory = 'C:/Users/conor/OneDrive/Documents/EAV_Data'

    if not os.path.exists(output_directory):
        os.makedirs(output_directory)

    process_data_file(data_file_path, output_directory)

    current_date = datetime.now().strftime('%Y-%m-%d')
    csv_file_path = os.path.join(output_directory, f'{current_date}.csv')

    if os.path.exists(csv_file_path):
        plot_gps_data(csv_file_path)
    else:
        print(f"Error: Today's data file could not be found at '{csv_file_path}'")


if __name__ == "__main__":
    main()
